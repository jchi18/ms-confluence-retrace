//@version=5
indicator("A+ Confluence Marker", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ============================================================================
//  A+ CONFLUENCE MARKER
//  -------------------------------------------------------------------------
//  Marks only STRONG, self-contained institutional confluences so you can line
//  up your OWN OTE. Each type only draws if it is A+ by itself:
//     FVG   - a SIGNIFICANT Fair Value Gap (size + optional displacement)
//     OB    - an Order Block from a DISPLACEMENT break (not chop)
//     RB    - a STRONG Rejection Block (long rejection wick)
//  Nothing is required to "stack" - each is a valid A+ POI on its own.
//  Every zone is anchored to the EXACT candle that formed it for precision.
//  Relevance filters keep the screen clean: only zones on the retrace side of
//  price, de-duped, capped. It does NOT mark entries/targets/OTE - you draw
//  your OTE; this shows the A+ POIs and alerts when price taps one.
// ============================================================================

// ---------------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------------
g1 = "1) Structure / strength baseline"
pivotLen = input.int(5, "Swing length", minval=2, maxval=50, group=g1, tooltip="Bars either side that define a swing. Drives OBs, RBs and sweep reference levels.")
atrLen   = input.int(14, "ATR length", minval=1, group=g1)
dispMult = input.float(1.3, "Displacement = ATR x", minval=0.2, step=0.1, group=g1, tooltip="A candle/break counts as institutional displacement when its range >= this x ATR.")

g2 = "2) Which A+ confluences"
useFVG   = input.bool(true, "FVG (significant only)", group=g2)
fvgMinATR= input.float(0.5, "  min FVG size (ATR x)", minval=0.0, step=0.05, group=g2, tooltip="Ignore gaps smaller than this. Raise to keep only big imbalances.")
fvgDisp  = input.bool(true, "  FVG needs a displacement candle", group=g2)
useOB    = input.bool(true, "Order Block (displacement break)", group=g2)
useRB    = input.bool(true, "Rejection Block (strong wick)", group=g2)
rbWick   = input.float(2.0, "  strong RB wick : body ratio", minval=0.5, step=0.1, group=g2)

g3 = "3) Relevance / declutter"
sideFilter = input.bool(true, "Only zones on the retrace side of price", group=g3, tooltip="Bullish POIs only below price (discount), bearish only above (premium). Main de-clutter filter.")
useHTF     = input.bool(false, "Only POIs aligned with HTF bias", group=g3)
htfTF      = input.timeframe("15", "HTF timeframe", group=g3)
htfPiv     = input.int(5, "HTF swing length", minval=2, maxval=50, group=g3)
maxLive    = input.int(8, "Max POIs on screen", minval=1, maxval=40, group=g3)

g4 = "4) Display"
showStruct= input.bool(false, "Show BOS / CHoCH labels", group=g4)
extendBars= input.int(30, "Extend zones (bars to the right)", minval=5, maxval=200, group=g4)
showTable = input.bool(true, "Show status table", group=g4)

g5 = "5) Signals & liquidity"
showSignals  = input.bool(true, "Fire BUY / SELL signals", group=g5, tooltip="A signal = price taps an A+ POI in the direction of bias + structure, with liquidity to target.")
reqBias      = input.bool(true, "Require HTF bias alignment", group=g5)
reqStructure = input.bool(true, "Require LTF structure alignment", group=g5, tooltip="Only long while structure is bullish (last break was a bullish BOS), only short while bearish.")
reqLiq       = input.bool(true, "Require a liquidity draw to target", group=g5, tooltip="Only signal if there is unswept liquidity (a swing high for longs / low for shorts) for price to run to.")
showLiq      = input.bool(true, "Draw nearest liquidity (BSL / SSL)", group=g5)
liqLook      = input.int(60, "Liquidity search depth (bars)", minval=10, maxval=500, group=g5, tooltip="How far back to keep unswept swing highs/lows as liquidity draws.")

bull = color.new(color.teal, 0)
bear = color.new(color.red, 0)
atr  = ta.atr(atrLen)

// ---------------------------------------------------------------------------
// HTF BIAS
// ---------------------------------------------------------------------------
f_htfTrend() =>
    var int   t   = 0
    var float lph = na
    var float lpl = na
    _ph = ta.pivothigh(high, htfPiv, htfPiv)
    _pl = ta.pivotlow(low,  htfPiv, htfPiv)
    if not na(_ph)
        lph := _ph
    if not na(_pl)
        lpl := _pl
    if not na(lph) and close > lph
        t := 1
    if not na(lpl) and close < lpl
        t := -1
    t
htfTrend = request.security(syminfo.tickerid, htfTF, f_htfTrend(), lookahead=barmerge.lookahead_off)

// ---------------------------------------------------------------------------
// ACTIVE POI STORE (drawn boxes we manage over time)
//   dir: 1 = bull, 0 = bear
// ---------------------------------------------------------------------------
var float[]  azTop  = array.new_float()
var float[]  azBot  = array.new_float()
var int[]    azDir  = array.new_int()
var box[]    azBox  = array.new_box()
var int[]    azTap  = array.new_int()
var string[] azKind = array.new_string()

f_kindCol(_kind) => _kind == "FVG" ? color.blue : _kind == "OB" ? color.purple : color.orange

// add an A+ POI: apply relevance + de-dupe, then draw and cap.
// _left = the exact bar the zone was formed on (precise anchor).
f_addPOI(_left, _top, _bot, _dir, _kind) =>
    ok = _top > _bot
    if ok and sideFilter
        ok := _dir == 1 ? _bot <= close : _top >= close
    if ok and useHTF
        ok := _dir == 1 ? htfTrend == 1 : htfTrend == -1
    if ok and array.size(azTop) > 0
        for k = 0 to array.size(azTop) - 1
            if array.get(azDir, k) == _dir and math.min(_top, array.get(azTop, k)) >= math.max(_bot, array.get(azBot, k))
                ok := false
    if ok
        base = f_kindCol(_kind)
        b = box.new(_left, _top, bar_index + extendBars, _bot, border_color=color.new(base, 20), border_width=2, bgcolor=color.new(base, 80), text=_kind, text_size=size.small, text_color=color.new(base, 0), text_halign=text.align_left, text_valign=text.align_center)
        array.push(azTop, _top)
        array.push(azBot, _bot)
        array.push(azDir, _dir)
        array.push(azTap, 0)
        array.push(azKind, _kind)
        array.push(azBox, b)
        if array.size(azTop) > maxLive
            box.delete(array.get(azBox, 0))
            array.remove(azTop, 0)
            array.remove(azBot, 0)
            array.remove(azDir, 0)
            array.remove(azTap, 0)
            array.remove(azKind, 0)
            array.remove(azBox, 0)

// ---------------------------------------------------------------------------
// 1) SIGNIFICANT FVGs
// ---------------------------------------------------------------------------
if useFVG and low > high[2]
    gap = low - high[2]
    dispOKc = (high[1] - low[1]) >= dispMult * atr
    if gap >= fvgMinATR * atr and (not fvgDisp or dispOKc)
        f_addPOI(bar_index - 2, low, high[2], 1, "FVG")
if useFVG and high < low[2]
    gap = low[2] - high
    dispOKc = (high[1] - low[1]) >= dispMult * atr
    if gap >= fvgMinATR * atr and (not fvgDisp or dispOKc)
        f_addPOI(bar_index - 2, low[2], high, 0, "FVG")

// ---------------------------------------------------------------------------
// 2) STRUCTURE + DISPLACEMENT ORDER BLOCKS
// ---------------------------------------------------------------------------
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,  pivotLen, pivotLen)
var float lastPH = na
var float lastPL = na
var int   trend  = 0
var float lastBrokeH = na
var float lastBrokeL = na
if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl
dispOK = (high - low) >= dispMult * atr
bullBreak = not na(lastPH) and close > lastPH and lastPH != lastBrokeH
bearBreak = not na(lastPL) and close < lastPL and lastPL != lastBrokeL
if bullBreak
    lastBrokeH := lastPH
    if dispOK
        wasBear = trend == -1
        trend := 1
        if useOB
            for i = 1 to 30
                if close[i] < open[i]
                    f_addPOI(bar_index - i, high[i], low[i], 1, "OB")
                    break
        if showStruct
            label.new(bar_index, high, wasBear ? "CHoCH" : "BOS", style=label.style_label_down, color=bull, textcolor=color.white, size=size.small)
if bearBreak
    lastBrokeL := lastPL
    if dispOK
        wasBull = trend == 1
        trend := -1
        if useOB
            for i = 1 to 30
                if close[i] > open[i]
                    f_addPOI(bar_index - i, high[i], low[i], 0, "OB")
                    break
        if showStruct
            label.new(bar_index, low, wasBull ? "CHoCH" : "BOS", style=label.style_label_up, color=bear, textcolor=color.white, size=size.small)

// ---------------------------------------------------------------------------
// 3) STRONG REJECTION BLOCKS
// ---------------------------------------------------------------------------
if useRB and not na(pl)
    lw = math.min(open[pivotLen], close[pivotLen]) - low[pivotLen]
    bd = math.abs(close[pivotLen] - open[pivotLen])
    if lw > bd * rbWick and lw > 0
        f_addPOI(bar_index - pivotLen, math.min(open[pivotLen], close[pivotLen]), low[pivotLen], 1, "RB")
if useRB and not na(ph)
    uw = high[pivotLen] - math.max(open[pivotLen], close[pivotLen])
    bd = math.abs(close[pivotLen] - open[pivotLen])
    if uw > bd * rbWick and uw > 0
        f_addPOI(bar_index - pivotLen, high[pivotLen], math.max(open[pivotLen], close[pivotLen]), 0, "RB")

// ---------------------------------------------------------------------------
// 4) MANAGE POIs: extend, detect live tap, mitigate
// ---------------------------------------------------------------------------
tapBull = false
tapBear = false
float tapBullStop = na
float tapBearStop = na
if array.size(azTop) > 0
    for i = array.size(azTop) - 1 to 0
        zt = array.get(azTop, i)
        zb = array.get(azBot, i)
        zd = array.get(azDir, i)
        bx = array.get(azBox, i)
        box.set_right(bx, bar_index + extendBars)
        if low <= zt and high >= zb and array.get(azTap, i) == 0
            array.set(azTap, i, 1)
            if zd == 1
                tapBull := true
                tapBullStop := zb
            else
                tapBear := true
                tapBearStop := zt
        gone = zd == 1 ? (close < zb) : (close > zt)
        if gone
            box.set_bgcolor(bx, color.new(color.gray, 92))
            box.set_border_color(bx, color.new(color.gray, 75))
            box.set_right(bx, bar_index)
            array.remove(azTop, i)
            array.remove(azBot, i)
            array.remove(azDir, i)
            array.remove(azBox, i)
            array.remove(azTap, i)
            array.remove(azKind, i)

liveBull = 0
liveBear = 0
if array.size(azDir) > 0
    for i = 0 to array.size(azDir) - 1
        if array.get(azDir, i) == 1
            liveBull := liveBull + 1
        else
            liveBear := liveBear + 1

// ---------------------------------------------------------------------------
// 5) DRAWS ON LIQUIDITY (unswept swing highs = BSL, swing lows = SSL)
// ---------------------------------------------------------------------------
var float[] hiLvl = array.new_float()
var int[]   hiBar = array.new_int()
var float[] loLvl = array.new_float()
var int[]   loBar = array.new_int()

// store confirmed swing points as resting liquidity
if not na(ph)
    array.push(hiLvl, ph)
    array.push(hiBar, bar_index - pivotLen)
if not na(pl)
    array.push(loLvl, pl)
    array.push(loBar, bar_index - pivotLen)

// drop liquidity that has been swept (traded through) or aged out
if array.size(hiLvl) > 0
    for i = array.size(hiLvl) - 1 to 0
        if high > array.get(hiLvl, i) or (bar_index - array.get(hiBar, i)) > liqLook
            array.remove(hiLvl, i)
            array.remove(hiBar, i)
if array.size(loLvl) > 0
    for i = array.size(loLvl) - 1 to 0
        if low < array.get(loLvl, i) or (bar_index - array.get(loBar, i)) > liqLook
            array.remove(loLvl, i)
            array.remove(loBar, i)

// nearest unswept draw above (BSL) and below (SSL)
float tgtBSL = na
int   barBSL = na
if array.size(hiLvl) > 0
    for i = 0 to array.size(hiLvl) - 1
        lv = array.get(hiLvl, i)
        if lv > close and (na(tgtBSL) or lv < tgtBSL)
            tgtBSL := lv
            barBSL := array.get(hiBar, i)
float tgtSSL = na
int   barSSL = na
if array.size(loLvl) > 0
    for i = 0 to array.size(loLvl) - 1
        lv = array.get(loLvl, i)
        if lv < close and (na(tgtSSL) or lv > tgtSSL)
            tgtSSL := lv
            barSSL := array.get(loBar, i)

// draw the two nearest draws as rays (one line each, updated in place)
var line bslLine = na
var line sslLine = na
var label bslLab = na
var label sslLab = na
if showLiq and not na(tgtBSL)
    if na(bslLine)
        bslLine := line.new(barBSL, tgtBSL, bar_index + extendBars, tgtBSL, color=color.new(color.green, 0), style=line.style_dashed, width=1)
        bslLab  := label.new(bar_index + extendBars, tgtBSL, "BSL", style=label.style_none, textcolor=color.new(color.green,0), size=size.small)
    else
        line.set_xy1(bslLine, barBSL, tgtBSL)
        line.set_xy2(bslLine, bar_index + extendBars, tgtBSL)
        label.set_xy(bslLab, bar_index + extendBars, tgtBSL)
else
    if not na(bslLine)
        line.delete(bslLine)
        label.delete(bslLab)
        bslLine := na
        bslLab := na
if showLiq and not na(tgtSSL)
    if na(sslLine)
        sslLine := line.new(barSSL, tgtSSL, bar_index + extendBars, tgtSSL, color=color.new(color.red, 0), style=line.style_dashed, width=1)
        sslLab  := label.new(bar_index + extendBars, tgtSSL, "SSL", style=label.style_none, textcolor=color.new(color.red,0), size=size.small)
    else
        line.set_xy1(sslLine, barSSL, tgtSSL)
        line.set_xy2(sslLine, bar_index + extendBars, tgtSSL)
        label.set_xy(sslLab, bar_index + extendBars, tgtSSL)
else
    if not na(sslLine)
        line.delete(sslLine)
        label.delete(sslLab)
        sslLine := na
        sslLab := na

// ---------------------------------------------------------------------------
// 6) SIGNALS  (A+ tap + bias + structure + a liquidity draw to target)
// ---------------------------------------------------------------------------
biasBull  = not reqBias or htfTrend == 1
biasBear  = not reqBias or htfTrend == -1
structBull= not reqStructure or trend == 1
structBear= not reqStructure or trend == -1
liqBull   = not reqLiq or not na(tgtBSL)
liqBear   = not reqLiq or not na(tgtSSL)

buySignal  = showSignals and tapBull and biasBull and structBull and liqBull
sellSignal = showSignals and tapBear and biasBear and structBear and liqBear

f_rr(_entry, _stop, _tgt) =>
    risk = math.abs(_entry - _stop)
    risk > 0 and not na(_tgt) ? math.abs(_tgt - _entry) / risk : na

if buySignal
    rrB = f_rr(close, tapBullStop, tgtBSL)
    label.new(bar_index, low, "BUY" + (na(rrB) ? "" : "  " + str.tostring(rrB, "#.#") + "R"), style=label.style_label_up, color=color.new(color.green,0), textcolor=color.white, size=size.normal)
    alert("BUY " + syminfo.ticker + " @ " + str.tostring(close) + "  | stop " + str.tostring(tapBullStop) + "  | target(BSL) " + str.tostring(tgtBSL) + (na(rrB) ? "" : "  | " + str.tostring(rrB, "#.#") + "R"), alert.freq_once_per_bar_close)
if sellSignal
    rrS = f_rr(close, tapBearStop, tgtSSL)
    label.new(bar_index, high, "SELL" + (na(rrS) ? "" : "  " + str.tostring(rrS, "#.#") + "R"), style=label.style_label_down, color=color.new(color.red,0), textcolor=color.white, size=size.normal)
    alert("SELL " + syminfo.ticker + " @ " + str.tostring(close) + "  | stop " + str.tostring(tapBearStop) + "  | target(SSL) " + str.tostring(tgtSSL) + (na(rrS) ? "" : "  | " + str.tostring(rrS, "#.#") + "R"), alert.freq_once_per_bar_close)

alertcondition(buySignal,  "BUY signal",  "BUY {{ticker}} @ {{close}} - A+ POI + bias + structure, target BSL")
alertcondition(sellSignal, "SELL signal", "SELL {{ticker}} @ {{close}} - A+ POI + bias + structure, target SSL")

// faint POI-tap markers (a tap that did NOT become a full signal)
plotshape(tapBull and not buySignal,  title="Bull POI tap", style=shape.triangleup,   location=location.belowbar, color=color.new(color.teal,40), size=size.tiny)
plotshape(tapBear and not sellSignal, title="Bear POI tap", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,40),  size=size.tiny)

// ---------------------------------------------------------------------------
// 7) STATUS TABLE
// ---------------------------------------------------------------------------
if showTable and barstate.islast
    var table tb = table.new(position.top_right, 2, 5, border_width=1)
    bgD = color.new(color.black, 30)
    table.cell(tb, 0, 0, "HTF bias", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 0, htfTrend==1?"Bull":htfTrend==-1?"Bear":"-", text_size=size.small, text_color=color.white, bgcolor=htfTrend==1?bull:htfTrend==-1?bear:color.gray)
    table.cell(tb, 0, 1, "Structure", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 1, trend==1?"Bull":trend==-1?"Bear":"-", text_size=size.small, text_color=color.white, bgcolor=trend==1?bull:trend==-1?bear:color.gray)
    table.cell(tb, 0, 2, "Next BSL", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 2, na(tgtBSL)?"-":str.tostring(tgtBSL), text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 3, "Next SSL", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 3, na(tgtSSL)?"-":str.tostring(tgtSSL), text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 4, "Live POIs", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 4, str.tostring(liveBull)+"L / "+str.tostring(liveBear)+"S", text_size=size.small, text_color=color.white, bgcolor=bgD)
