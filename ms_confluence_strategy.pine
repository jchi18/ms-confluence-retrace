//@version=5
strategy("MS Confluence Retrace [HTF + FVG/OB/RB]", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.02, pyramiding=0, calc_on_every_tick=false)

// ============================================================================
//  Enter on a structure retrace when >=1 trend-aligned confluence overlaps
//  (FVG / OB / RB / Fib pocket) AND the setup "makes sense":
//   - HTF bias aligned  - retrace into discount(long)/premium(short)  - confirmation
// ============================================================================

// ---------------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------------
gA = "Setup Quality"
minConf     = input.int(1, "Min confluences", minval=1, maxval=4, group=gA, tooltip="How many of {FVG, OB, RB, Fib pocket} must overlap the retrace. 1 is enough — the guards below keep it sensible.")
reqHTF      = input.bool(true, "Require HTF bias alignment", group=gA)
enforceDisc = input.bool(true, "Only enter in discount / premium", group=gA, tooltip="Longs must retrace below 50% of the leg; shorts above 50%.")

gS = "Structure"
pivotLen = input.int(5, "LTF Swing Length", minval=2, maxval=50, group=gS, tooltip="Bars each side of a swing. 3-4 aggressive, 5-7 clean.")

gH = "Higher-Timeframe Bias"
htfTF   = input.timeframe("15", "HTF Timeframe", group=gH)
htfPiv  = input.int(5, "HTF Swing Length", minval=2, maxval=50, group=gH)

gC = "Confluence params"
fibLo  = input.float(0.5,   "Fib pocket start", step=0.01, group=gC)
fibHi  = input.float(0.618, "Fib pocket end",   step=0.01, group=gC)
rbWick = input.float(1.5, "Rejection wick : body ratio", step=0.1, group=gC)

gT = "Trade"
rr        = input.float(2.0, "Risk:Reward (TP)", minval=0.5, step=0.5, group=gT)
useSession= input.bool(false, "Restrict to session", group=gT)
sess      = input.session("0930-1600", "Session", group=gT)

gR = "Risk Management"
atrLen     = input.int(14, "ATR length", minval=1, group=gR)
useMaxStop = input.bool(true, "Cap max stop distance", group=gR)
maxStopATR = input.float(3.0, "Max stop = ATR x", minval=0.5, step=0.5, group=gR)
useBE      = input.bool(true, "Move stop to breakeven", group=gR)
beTrigR    = input.float(1.0, "Breakeven trigger (R)", minval=0.1, step=0.1, group=gR)
beLockR    = input.float(0.1, "Breakeven lock (R)", minval=0.0, step=0.05, group=gR)
useTrail   = input.bool(true, "Trailing stop (ATR)", group=gR)
trailATR   = input.float(1.5, "Trail distance = ATR x", minval=0.2, step=0.1, group=gR)

gD = "Display"
showZones = input.bool(true, "Draw FVG / OB / RB zones", group=gD)
showStruct= input.bool(true, "Show BOS / CHoCH", group=gD)
showTable = input.bool(true, "Show status table", group=gD)

bull = color.new(color.teal, 0)
bear = color.new(color.red, 0)
cFVG = color.new(color.blue, 82)
cOB  = color.new(color.purple, 78)
cRB  = color.new(color.orange, 78)

need = minConf
atr  = ta.atr(atrLen)
inSess = not useSession or not na(time(timeframe.period, sess))

// ---------------------------------------------------------------------------
// FUNCTIONS (all at global scope)
// ---------------------------------------------------------------------------
f_htfTrend() =>
    var int   t   = 0
    var float lph = na
    var float lpl = na
    _ph = ta.pivothigh(high, htfPiv, htfPiv)
    _pl = ta.pivotlow(low,  htfPiv, htfPiv)
    if not na(_ph)
        lph := _ph
    if not na(_pl)
        lpl := _pl
    if not na(lph) and close > lph
        t := 1
    if not na(lpl) and close < lpl
        t := -1
    t

f_fib(_s, _e, _r) => _e - (_e - _s) * _r

f_cellCol(v) => v == 1 ? bull : v == -1 ? bear : color.gray

// ---------------------------------------------------------------------------
// 1) HTF MARKET STRUCTURE (bias gate)
// ---------------------------------------------------------------------------
htfTrend = request.security(syminfo.tickerid, htfTF, f_htfTrend(), lookahead=barmerge.lookahead_off)
htfOK_long  = not reqHTF or htfTrend == 1
htfOK_short = not reqHTF or htfTrend == -1

// ---------------------------------------------------------------------------
// 2) LTF STRUCTURE (BOS / CHoCH) + impulse leg + Order Blocks
// ---------------------------------------------------------------------------
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,  pivotLen, pivotLen)

var float lastPH = na
var float lastPL = na
var int   trend  = 0
var float legStart = na
var float legEnd   = na
var int   legDir   = 0
var bool  legActive = false
var float lastBrokeH = na
var float lastBrokeL = na
var float obBullTop = na
var float obBullBot = na
var float obBearTop = na
var float obBearBot = na

if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl

bullBreak = not na(lastPH) and close > lastPH and lastPH != lastBrokeH
bearBreak = not na(lastPL) and close < lastPL and lastPL != lastBrokeL

if bullBreak
    lastBrokeH := lastPH
    legStart := not na(lastPL) ? lastPL : low
    legEnd   := lastPH
    legDir   := 1
    legActive := true
    wasBear = trend == -1
    trend := 1
    for i = 1 to 30
        if close[i] < open[i]
            obBullTop := high[i]
            obBullBot := low[i]
            break
    if showStruct
        label.new(bar_index, high, wasBear ? "CHoCH" : "BOS", style=label.style_label_down, color=bull, textcolor=color.white, size=size.small)
    if showZones and not na(obBullBot)
        box.new(bar_index-1, obBullTop, bar_index+25, obBullBot, border_color=color.new(color.purple,40), bgcolor=cOB, text="OB", text_size=size.tiny, text_color=color.new(color.purple,0))

if bearBreak
    lastBrokeL := lastPL
    legStart := not na(lastPH) ? lastPH : high
    legEnd   := lastPL
    legDir   := -1
    legActive := true
    wasBull = trend == 1
    trend := -1
    for i = 1 to 30
        if close[i] > open[i]
            obBearTop := high[i]
            obBearBot := low[i]
            break
    if showStruct
        label.new(bar_index, low, wasBull ? "CHoCH" : "BOS", style=label.style_label_up, color=bear, textcolor=color.white, size=size.small)
    if showZones and not na(obBearBot)
        box.new(bar_index-1, obBearTop, bar_index+25, obBearBot, border_color=color.new(color.purple,40), bgcolor=cOB, text="OB", text_size=size.tiny, text_color=color.new(color.purple,0))

// ---------------------------------------------------------------------------
// 3) FVGs (stored + auto-mitigated)
// ---------------------------------------------------------------------------
var float[] fvTop  = array.new_float()
var float[] fvBot  = array.new_float()
var int[]   fvBull = array.new_int()

if low > high[2]
    array.push(fvTop, low)
    array.push(fvBot, high[2])
    array.push(fvBull, 1)
    if showZones
        box.new(bar_index-2, low, bar_index+10, high[2], border_color=na, bgcolor=cFVG)
if high < low[2]
    array.push(fvTop, low[2])
    array.push(fvBot, high)
    array.push(fvBull, 0)
    if showZones
        box.new(bar_index-2, low[2], bar_index+10, high, border_color=na, bgcolor=cFVG)

if array.size(fvTop) > 0
    for i = array.size(fvTop) - 1 to 0
        ft = array.get(fvTop, i)
        fb = array.get(fvBot, i)
        isB = array.get(fvBull, i) == 1
        filled = isB ? (low < fb) : (high > ft)
        if filled or array.size(fvTop) > 40
            array.remove(fvTop, i)
            array.remove(fvBot, i)
            array.remove(fvBull, i)

f_inFVG(_bull) =>
    hit = false
    if array.size(fvTop) > 0
        for i = 0 to array.size(fvTop) - 1
            same = (array.get(fvBull, i) == 1) == _bull
            if same and low <= array.get(fvTop, i) and high >= array.get(fvBot, i)
                hit := true
    hit

// ---------------------------------------------------------------------------
// 4) REJECTION BLOCKS (long-wick rejection at the leg-origin swing)
// ---------------------------------------------------------------------------
var float rbBullTop = na
var float rbBullBot = na
var float rbBearTop = na
var float rbBearBot = na

if not na(pl)
    lw = math.min(open[pivotLen], close[pivotLen]) - low[pivotLen]
    bd = math.abs(close[pivotLen] - open[pivotLen])
    if lw > bd * rbWick and lw > 0
        rbBullTop := math.min(open[pivotLen], close[pivotLen])
        rbBullBot := low[pivotLen]
        if showZones
            box.new(bar_index-pivotLen, rbBullTop, bar_index+20, rbBullBot, border_color=color.new(color.orange,40), bgcolor=cRB, text="RB", text_size=size.tiny, text_color=color.new(color.orange,0))
if not na(ph)
    uw = high[pivotLen] - math.max(open[pivotLen], close[pivotLen])
    bd = math.abs(close[pivotLen] - open[pivotLen])
    if uw > bd * rbWick and uw > 0
        rbBearTop := high[pivotLen]
        rbBearBot := math.max(open[pivotLen], close[pivotLen])
        if showZones
            box.new(bar_index-pivotLen, rbBearTop, bar_index+20, rbBearBot, border_color=color.new(color.orange,40), bgcolor=cRB, text="RB", text_size=size.tiny, text_color=color.new(color.orange,0))

f_inRB(_bull) =>
    _bull ? (not na(rbBullBot) and low <= rbBullTop and high >= rbBullBot) : (not na(rbBearBot) and high >= rbBearBot and low <= rbBearTop)

// ---------------------------------------------------------------------------
// 5) FIB POCKET
// ---------------------------------------------------------------------------
float fibA = na
float fibB = na
if legActive
    fibA := f_fib(legStart, legEnd, fibLo)
    fibB := f_fib(legStart, legEnd, fibHi)
inFibLong  = legActive and legDir == 1  and low  <= math.max(fibA,fibB) and low  >= math.min(fibA,fibB)
inFibShort = legActive and legDir == -1 and high >= math.min(fibA,fibB) and high <= math.max(fibA,fibB)

// ---------------------------------------------------------------------------
// 6) CONFLUENCE SCORE + ENTRY CONDITIONS
// ---------------------------------------------------------------------------
inOBLong  = not na(obBullBot) and low  <= obBullTop and high >= obBullBot
inOBShort = not na(obBearBot) and high >= obBearBot and low  <= obBearTop

scoreLong  = (inFibLong ? 1 : 0)  + (f_inFVG(true) ? 1 : 0)  + (inOBLong ? 1 : 0)  + (f_inRB(true) ? 1 : 0)
scoreShort = (inFibShort ? 1 : 0) + (f_inFVG(false) ? 1 : 0) + (inOBShort ? 1 : 0) + (f_inRB(false) ? 1 : 0)

var bool longTaken  = false
var bool shortTaken = false
if bullBreak
    longTaken := false
if bearBreak
    shortTaken := false

validLongStop  = not na(legStart) and legStart < close
validShortStop = not na(legStart) and legStart > close

midLevel   = legActive ? f_fib(legStart, legEnd, 0.5) : na
senseLong  = not enforceDisc or (not na(midLevel) and low  <= midLevel)
senseShort = not enforceDisc or (not na(midLevel) and high >= midLevel)

stopOKLong  = not useMaxStop or (not na(legStart) and (close - legStart) <= maxStopATR * atr)
stopOKShort = not useMaxStop or (not na(legStart) and (legStart - close) <= maxStopATR * atr)

goLong  = legActive and legDir == 1  and htfOK_long  and scoreLong  >= need and senseLong  and close > open and validLongStop  and stopOKLong  and not longTaken  and inSess
goShort = legActive and legDir == -1 and htfOK_short and scoreShort >= need and senseShort and close < open and validShortStop and stopOKShort and not shortTaken and inSess

// ---------------------------------------------------------------------------
// 7) ENTRIES + POSITION MANAGEMENT (breakeven + ATR trail)
// ---------------------------------------------------------------------------
var float entryPx  = na
var float initStop = na
var float curStop  = na
var float curTP    = na
var float extreme  = na
var int   posDir   = 0

if goLong
    entryPx  := close
    initStop := legStart
    curStop  := legStart
    curTP    := close + (close - legStart) * rr
    extreme  := high
    posDir   := 1
    longTaken := true
    legActive := false
    strategy.entry("Long", strategy.long)
if goShort
    entryPx  := close
    initStop := legStart
    curStop  := legStart
    curTP    := close - (legStart - close) * rr
    extreme  := low
    posDir   := -1
    shortTaken := true
    legActive := false
    strategy.entry("Short", strategy.short)

inPos = strategy.position_size != 0
if inPos and posDir == 1
    extreme := math.max(extreme, high)
    rLong = entryPx - initStop
    cand = curStop
    if useBE and rLong > 0 and (high - entryPx) >= beTrigR * rLong
        cand := math.max(cand, entryPx + beLockR * rLong)
    if useTrail
        cand := math.max(cand, extreme - trailATR * atr)
    curStop := math.max(curStop, cand)
    strategy.exit("XL", "Long", stop=curStop, limit=curTP)
if inPos and posDir == -1
    extreme := math.min(extreme, low)
    rShort = initStop - entryPx
    cand = curStop
    if useBE and rShort > 0 and (entryPx - low) >= beTrigR * rShort
        cand := math.min(cand, entryPx - beLockR * rShort)
    if useTrail
        cand := math.min(cand, extreme + trailATR * atr)
    curStop := math.min(curStop, cand)
    strategy.exit("XS", "Short", stop=curStop, limit=curTP)

// ---------------------------------------------------------------------------
// 8) VISUALS
// ---------------------------------------------------------------------------
plot(inPos ? curStop : na, "Live Stop",   color=color.new(color.red,0),  style=plot.style_linebr, linewidth=1)
plot(inPos ? curTP   : na, "Live Target", color=color.new(color.teal,0), style=plot.style_linebr, linewidth=1)
plotshape(goLong,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=bull, size=size.small, text="LONG")
plotshape(goShort, title="Short", style=shape.triangledown, location=location.abovebar, color=bear, size=size.small, text="SHORT")

alertcondition(goLong,  "Long Entry",  "LONG {{ticker}} @ {{close}} | structure retrace + confluence")
alertcondition(goShort, "Short Entry", "SHORT {{ticker}} @ {{close}} | structure retrace + confluence")

if showTable and barstate.islast
    var table tb = table.new(position.top_right, 2, 6, border_width=1)
    bgD = color.new(color.black, 30)
    table.cell(tb, 0, 0, "HTF bias", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 0, htfTrend==1?"Bull":htfTrend==-1?"Bear":"-", text_size=size.small, text_color=color.white, bgcolor=f_cellCol(htfTrend))
    table.cell(tb, 0, 1, "LTF trend", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 1, trend==1?"Bull":trend==-1?"Bear":"-", text_size=size.small, text_color=color.white, bgcolor=f_cellCol(trend))
    table.cell(tb, 0, 2, "Long conf", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 2, str.tostring(scoreLong)+"/4", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 3, "Short conf", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 3, str.tostring(scoreShort)+"/4", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 4, "Needs", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 4, str.tostring(need)+"/4", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 5, "Active leg", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 5, legActive?(legDir==1?"Long setup":"Short setup"):"-", text_size=size.small, text_color=color.white, bgcolor=bgD)
