//@version=5
indicator("MS Confluence Retrace v2 [Indicator]", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ============================================================================
//  Alert-only twin of the v2 strategy. Same structure/confluence engine plus
//  the v2 filters (displacement, liquidity sweep, min/max stop band, partial TP,
//  guardrails). No orders - it tracks a VIRTUAL position (with real R accounting)
//  to draw the live stop/targets and fire entry / partial / exit alerts.
//  The entry alert also reports the size to trade for your account + risk %.
// ============================================================================

// ---------------------------------------------------------------------------
// INPUTS
// ---------------------------------------------------------------------------
g1 = "1) Setup Quality"
minConf     = input.int(2, "Min confluences", minval=1, maxval=4, group=g1)
reqHTF      = input.bool(true, "Require HTF bias alignment", group=g1)
enforceDisc = input.bool(true, "Only enter in discount / premium", group=g1)

g2 = "2) Structure"
pivotLen = input.int(5, "LTF Swing Length", minval=2, maxval=50, group=g2)

g3 = "3) HTF Bias"
htfTF   = input.timeframe("15", "HTF Timeframe", group=g3)
htfPiv  = input.int(5, "HTF Swing Length", minval=2, maxval=50, group=g3)

g4 = "4) Confluence"
fibLo  = input.float(0.5,   "Fib pocket start", step=0.01, group=g4)
fibHi  = input.float(0.618, "Fib pocket end",   step=0.01, group=g4)
rbWick = input.float(1.5, "Rejection wick : body ratio", step=0.1, group=g4)

g5 = "5) Entry Filters"
useDisp   = input.bool(true, "Require displacement on the break", group=g5, tooltip="Breaking candle range must be >= mult x ATR.")
dispMult  = input.float(1.2, "Displacement = ATR x", minval=0.2, step=0.1, group=g5)
useSweep  = input.bool(true, "Require a liquidity sweep + reclaim", group=g5)
sweepLook = input.int(6, "Sweep lookback (bars)", minval=2, maxval=50, group=g5)
useSession= input.bool(false, "Restrict to session", group=g5)
sess      = input.session("0930-1600", "Session", group=g5)

g6 = "6) Exits & Targets"
rr        = input.float(2.0, "Runner target (R)", minval=0.5, step=0.5, group=g6)
usePartial= input.bool(true, "Scale out a partial at 1R", group=g6)
tp1RR     = input.float(1.0, "Partial target (R)", minval=0.2, step=0.1, group=g6)
tp1Perc   = input.float(50, "Partial size (% of position)", minval=5, maxval=95, step=5, group=g6)

g7 = "7) Risk & Sizing"
acctSize   = input.float(0, "Account size (0 = don't size)", minval=0, step=100, group=g7, tooltip="If set, the entry alert reports how many units to trade so a stop-out loses 'Risk %' of this.")
riskPerc   = input.float(0.5, "Risk % of account / trade", minval=0.05, step=0.05, group=g7)
atrLen     = input.int(14, "ATR length", minval=1, group=g7)
useMaxStop = input.bool(true, "Cap max stop distance", group=g7)
maxStopATR = input.float(3.0, "Max stop = ATR x", minval=0.5, step=0.5, group=g7)
useMinStop = input.bool(true, "Floor min stop distance", group=g7)
minStopATR = input.float(0.5, "Min stop = ATR x", minval=0.1, step=0.1, group=g7)
useBE      = input.bool(true, "Move stop to breakeven", group=g7)
beTrigR    = input.float(1.0, "Breakeven trigger (R)", minval=0.1, step=0.1, group=g7)
beLockR    = input.float(0.05, "Breakeven lock (R)", minval=0.0, step=0.05, group=g7)
useTrail   = input.bool(true, "Trailing stop (ATR)", group=g7)
trailATR   = input.float(1.5, "Trail distance = ATR x", minval=0.2, step=0.1, group=g7)

g8 = "8) Guardrails"
useDailyLoss  = input.bool(true, "Daily loss limit (in R)", group=g8)
maxDailyLossR = input.float(2.0, "Stop for the day at -R", minval=0.5, step=0.5, group=g8, tooltip="Cumulative realized R for the day. -2 = stop after losing 2R net today.")
useLossStreak = input.bool(true, "Consecutive-loss lockout", group=g8)
maxLossStreak = input.int(3, "Lock out after N losses in a row", minval=1, maxval=20, group=g8)

g9 = "9) Display"
showZones = input.bool(true, "Draw FVG / OB / RB zones", group=g9)
showStruct= input.bool(true, "Show BOS / CHoCH", group=g9)
showTable = input.bool(true, "Show status table", group=g9)
showPerf  = input.bool(true, "Show performance table", group=g9)

bull = color.new(color.teal, 0)
bear = color.new(color.red, 0)
cFVG = color.new(color.blue, 82)
cOB  = color.new(color.purple, 78)
cRB  = color.new(color.orange, 78)

need = minConf
atr  = ta.atr(atrLen)
inSess = not useSession or not na(time(timeframe.period, sess))

// ---------------------------------------------------------------------------
// FUNCTIONS (global scope)
// ---------------------------------------------------------------------------
f_htfTrend() =>
    var int   t   = 0
    var float lph = na
    var float lpl = na
    _ph = ta.pivothigh(high, htfPiv, htfPiv)
    _pl = ta.pivotlow(low,  htfPiv, htfPiv)
    if not na(_ph)
        lph := _ph
    if not na(_pl)
        lpl := _pl
    if not na(lph) and close > lph
        t := 1
    if not na(lpl) and close < lpl
        t := -1
    t
f_fib(_s, _e, _r) => _e - (_e - _s) * _r
f_cellCol(v) => v == 1 ? bull : v == -1 ? bear : color.gray

// ---------------------------------------------------------------------------
// 1) HTF STRUCTURE
// ---------------------------------------------------------------------------
htfTrend = request.security(syminfo.tickerid, htfTF, f_htfTrend(), lookahead=barmerge.lookahead_off)
htfOK_long  = not reqHTF or htfTrend == 1
htfOK_short = not reqHTF or htfTrend == -1

// ---------------------------------------------------------------------------
// 2) LTF STRUCTURE + DISPLACEMENT + OB
// ---------------------------------------------------------------------------
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,  pivotLen, pivotLen)
var float lastPH = na
var float lastPL = na
var int   trend  = 0
var float legStart = na
var float legEnd   = na
var int   legDir   = 0
var bool  legActive = false
var bool  legDisp   = false
var float lastBrokeH = na
var float lastBrokeL = na
var float obBullTop = na
var float obBullBot = na
var float obBearTop = na
var float obBearBot = na
if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl
dispOK = (high - low) >= dispMult * atr
bullBreak = not na(lastPH) and close > lastPH and lastPH != lastBrokeH
bearBreak = not na(lastPL) and close < lastPL and lastPL != lastBrokeL
if bullBreak
    lastBrokeH := lastPH
    if not useDisp or dispOK
        legStart := not na(lastPL) ? lastPL : low
        legEnd   := lastPH
        legDir   := 1
        legActive := true
        legDisp  := dispOK
        wasBear = trend == -1
        trend := 1
        for i = 1 to 30
            if close[i] < open[i]
                obBullTop := high[i]
                obBullBot := low[i]
                break
        if showStruct
            label.new(bar_index, high, wasBear ? "CHoCH" : "BOS", style=label.style_label_down, color=bull, textcolor=color.white, size=size.small)
        if showZones and not na(obBullBot)
            box.new(bar_index-1, obBullTop, bar_index+25, obBullBot, border_color=color.new(color.purple,40), bgcolor=cOB, text="OB", text_size=size.tiny, text_color=color.new(color.purple,0))
if bearBreak
    lastBrokeL := lastPL
    if not useDisp or dispOK
        legStart := not na(lastPH) ? lastPH : high
        legEnd   := lastPL
        legDir   := -1
        legActive := true
        legDisp  := dispOK
        wasBull = trend == 1
        trend := -1
        for i = 1 to 30
            if close[i] > open[i]
                obBearTop := high[i]
                obBearBot := low[i]
                break
        if showStruct
            label.new(bar_index, low, wasBull ? "CHoCH" : "BOS", style=label.style_label_up, color=bear, textcolor=color.white, size=size.small)
        if showZones and not na(obBearBot)
            box.new(bar_index-1, obBearTop, bar_index+25, obBearBot, border_color=color.new(color.purple,40), bgcolor=cOB, text="OB", text_size=size.tiny, text_color=color.new(color.purple,0))

// ---------------------------------------------------------------------------
// 3) FVGs
// ---------------------------------------------------------------------------
var float[] fvTop  = array.new_float()
var float[] fvBot  = array.new_float()
var int[]   fvBull = array.new_int()
if low > high[2]
    array.push(fvTop, low)
    array.push(fvBot, high[2])
    array.push(fvBull, 1)
    if showZones
        box.new(bar_index-2, low, bar_index+10, high[2], border_color=na, bgcolor=cFVG)
if high < low[2]
    array.push(fvTop, low[2])
    array.push(fvBot, high)
    array.push(fvBull, 0)
    if showZones
        box.new(bar_index-2, low[2], bar_index+10, high, border_color=na, bgcolor=cFVG)
if array.size(fvTop) > 0
    for i = array.size(fvTop) - 1 to 0
        ft = array.get(fvTop, i)
        fb = array.get(fvBot, i)
        isB = array.get(fvBull, i) == 1
        filled = isB ? (low < fb) : (high > ft)
        if filled or array.size(fvTop) > 40
            array.remove(fvTop, i)
            array.remove(fvBot, i)
            array.remove(fvBull, i)
f_inFVG(_bull) =>
    hit = false
    if array.size(fvTop) > 0
        for i = 0 to array.size(fvTop) - 1
            same = (array.get(fvBull, i) == 1) == _bull
            if same and low <= array.get(fvTop, i) and high >= array.get(fvBot, i)
                hit := true
    hit

// ---------------------------------------------------------------------------
// 4) REJECTION BLOCKS
// ---------------------------------------------------------------------------
var float rbBullTop = na
var float rbBullBot = na
var float rbBearTop = na
var float rbBearBot = na
if not na(pl)
    lw = math.min(open[pivotLen], close[pivotLen]) - low[pivotLen]
    bd = math.abs(close[pivotLen] - open[pivotLen])
    if lw > bd * rbWick and lw > 0
        rbBullTop := math.min(open[pivotLen], close[pivotLen])
        rbBullBot := low[pivotLen]
        if showZones
            box.new(bar_index-pivotLen, rbBullTop, bar_index+20, rbBullBot, border_color=color.new(color.orange,40), bgcolor=cRB, text="RB", text_size=size.tiny, text_color=color.new(color.orange,0))
if not na(ph)
    uw = high[pivotLen] - math.max(open[pivotLen], close[pivotLen])
    bd = math.abs(close[pivotLen] - open[pivotLen])
    if uw > bd * rbWick and uw > 0
        rbBearTop := high[pivotLen]
        rbBearBot := math.max(open[pivotLen], close[pivotLen])
        if showZones
            box.new(bar_index-pivotLen, rbBearTop, bar_index+20, rbBearBot, border_color=color.new(color.orange,40), bgcolor=cRB, text="RB", text_size=size.tiny, text_color=color.new(color.orange,0))
f_inRB(_bull) =>
    _bull ? (not na(rbBullBot) and low <= rbBullTop and high >= rbBullBot) : (not na(rbBearBot) and high >= rbBearBot and low <= rbBearTop)

// ---------------------------------------------------------------------------
// 5) FIB POCKET + LIQUIDITY SWEEP
// ---------------------------------------------------------------------------
float fibA = na
float fibB = na
if legActive
    fibA := f_fib(legStart, legEnd, fibLo)
    fibB := f_fib(legStart, legEnd, fibHi)
inFibLong  = legActive and legDir == 1  and low  <= math.max(fibA,fibB) and low  >= math.min(fibA,fibB)
inFibShort = legActive and legDir == -1 and high >= math.min(fibA,fibB) and high <= math.max(fibA,fibB)
lowestN  = ta.lowest(low, sweepLook)[1]
highestN = ta.highest(high, sweepLook)[1]
sweepLong  = not useSweep or (not na(lowestN)  and low  < lowestN  and close > lowestN)
sweepShort = not useSweep or (not na(highestN) and high > highestN and close < highestN)

// ---------------------------------------------------------------------------
// 6) SCORE + ENTRY GATES
// ---------------------------------------------------------------------------
inOBLong  = not na(obBullBot) and low  <= obBullTop and high >= obBullBot
inOBShort = not na(obBearBot) and high >= obBearBot and low  <= obBearTop
scoreLong  = (inFibLong ? 1 : 0)  + (f_inFVG(true) ? 1 : 0)  + (inOBLong ? 1 : 0)  + (f_inRB(true) ? 1 : 0)
scoreShort = (inFibShort ? 1 : 0) + (f_inFVG(false) ? 1 : 0) + (inOBShort ? 1 : 0) + (f_inRB(false) ? 1 : 0)
var bool longTaken  = false
var bool shortTaken = false
if bullBreak
    longTaken := false
if bearBreak
    shortTaken := false
validLongStop  = not na(legStart) and legStart < close
validShortStop = not na(legStart) and legStart > close
midLevel   = legActive ? f_fib(legStart, legEnd, 0.5) : na
senseLong  = not enforceDisc or (not na(midLevel) and low  <= midLevel)
senseShort = not enforceDisc or (not na(midLevel) and high >= midLevel)
dLong  = not na(legStart) ? close - legStart : na
dShort = not na(legStart) ? legStart - close : na
stopOKLong  = (not useMaxStop or (not na(dLong)  and dLong  <= maxStopATR * atr)) and (not useMinStop or (not na(dLong)  and dLong  >= minStopATR * atr))
stopOKShort = (not useMaxStop or (not na(dShort) and dShort <= maxStopATR * atr)) and (not useMinStop or (not na(dShort) and dShort >= minStopATR * atr))
dispValidLong  = not useDisp or legDisp
dispValidShort = not useDisp or legDisp

// ---------------------------------------------------------------------------
// 7) VIRTUAL POSITION (partial TP + BE/trail) + R ACCOUNTING + GUARDRAILS
// ---------------------------------------------------------------------------
var int   posDir   = 0
var float entryPx  = na
var float initStop = na
var float curStop  = na
var float curTP    = na
var float tp1Px    = na
var float extreme  = na
var bool  tookPartial = false
var int   tradeCount = 0
var int   winCount   = 0
var float sumR       = 0.0
var float dayR       = 0.0
var int   lossStreak = 0

partialHit = false
exitHit = false
float tradeR = na

// new-day reset for guardrails
isNewDay = ta.change(time("D")) != 0
if isNewDay
    dayR := 0.0
    lossStreak := 0

// --- manage an OPEN virtual position ---
if posDir == 1
    extreme := math.max(extreme, high)
    rLong = entryPx - initStop
    cand = curStop
    if useBE and rLong > 0 and (high - entryPx) >= beTrigR * rLong
        cand := math.max(cand, entryPx + beLockR * rLong)
    if useTrail
        cand := math.max(cand, extreme - trailATR * atr)
    curStop := math.max(curStop, cand)
    if usePartial and not tookPartial and high >= tp1Px
        tookPartial := true
        partialHit := true
        curStop := math.max(curStop, entryPx)
    if low <= curStop
        exitR = rLong > 0 ? (curStop - entryPx) / rLong : 0.0
        tradeR := (usePartial and tookPartial) ? (tp1Perc/100) * tp1RR + (1 - tp1Perc/100) * exitR : exitR
        posDir := 0
        exitHit := true
    else if high >= curTP
        exitR = rLong > 0 ? (curTP - entryPx) / rLong : 0.0
        tradeR := (usePartial and tookPartial) ? (tp1Perc/100) * tp1RR + (1 - tp1Perc/100) * exitR : exitR
        posDir := 0
        exitHit := true
if posDir == -1
    extreme := math.min(extreme, low)
    rShort = initStop - entryPx
    cand = curStop
    if useBE and rShort > 0 and (entryPx - low) >= beTrigR * rShort
        cand := math.min(cand, entryPx - beLockR * rShort)
    if useTrail
        cand := math.min(cand, extreme + trailATR * atr)
    curStop := math.min(curStop, cand)
    if usePartial and not tookPartial and low <= tp1Px
        tookPartial := true
        partialHit := true
        curStop := math.min(curStop, entryPx)
    if high >= curStop
        exitR = rShort > 0 ? (entryPx - curStop) / rShort : 0.0
        tradeR := (usePartial and tookPartial) ? (tp1Perc/100) * tp1RR + (1 - tp1Perc/100) * exitR : exitR
        posDir := 0
        exitHit := true
    else if low <= curTP
        exitR = rShort > 0 ? (entryPx - curTP) / rShort : 0.0
        tradeR := (usePartial and tookPartial) ? (tp1Perc/100) * tp1RR + (1 - tp1Perc/100) * exitR : exitR
        posDir := 0
        exitHit := true

// --- book a closed virtual trade ---
if not na(tradeR)
    tradeCount := tradeCount + 1
    sumR := sumR + tradeR
    dayR := dayR + tradeR
    if tradeR > 0
        winCount := winCount + 1
        lossStreak := 0
    else
        lossStreak := lossStreak + 1

// --- guardrail lockout ---
dailyLossHit = useDailyLoss and dayR <= -maxDailyLossR
streakHit    = useLossStreak and lossStreak >= maxLossStreak
lockout = dailyLossHit or streakHit

// --- entries (only when flat & not locked out) ---
goLong  = posDir == 0 and legActive and legDir == 1  and htfOK_long  and scoreLong  >= need and senseLong  and dispValidLong  and sweepLong  and close > open and validLongStop  and stopOKLong  and not longTaken  and inSess and not lockout
goShort = posDir == 0 and legActive and legDir == -1 and htfOK_short and scoreShort >= need and senseShort and dispValidShort and sweepShort and close < open and validShortStop and stopOKShort and not shortTaken and inSess and not lockout

float sizeLong  = na
float sizeShort = na
if goLong
    entryPx  := close
    initStop := legStart
    curStop  := legStart
    curTP    := close + (close - legStart) * rr
    tp1Px    := close + (close - legStart) * tp1RR
    extreme  := high
    posDir   := 1
    tookPartial := false
    longTaken := true
    legActive := false
    sizeLong := acctSize > 0 ? (acctSize * riskPerc / 100) / (close - legStart) : na
    alert("LONG " + syminfo.ticker + " @ " + str.tostring(close) + "  | stop " + str.tostring(initStop) + "  | TP1 " + str.tostring(tp1Px) + "  | runner " + str.tostring(curTP) + (acctSize > 0 ? "  | size " + str.tostring(sizeLong, "#.####") + " units" : ""), alert.freq_once_per_bar_close)
if goShort
    entryPx  := close
    initStop := legStart
    curStop  := legStart
    curTP    := close - (legStart - close) * rr
    tp1Px    := close - (legStart - close) * tp1RR
    extreme  := low
    posDir   := -1
    tookPartial := false
    shortTaken := true
    legActive := false
    sizeShort := acctSize > 0 ? (acctSize * riskPerc / 100) / (legStart - close) : na
    alert("SHORT " + syminfo.ticker + " @ " + str.tostring(close) + "  | stop " + str.tostring(initStop) + "  | TP1 " + str.tostring(tp1Px) + "  | runner " + str.tostring(curTP) + (acctSize > 0 ? "  | size " + str.tostring(sizeShort, "#.####") + " units" : ""), alert.freq_once_per_bar_close)

if partialHit
    alert("PARTIAL " + syminfo.ticker + " @ " + str.tostring(close) + "  | took " + str.tostring(tp1Perc, "#") + "% at 1R, stop to breakeven", alert.freq_once_per_bar_close)
if exitHit
    alert("EXIT " + syminfo.ticker + " @ " + str.tostring(close) + "  | trade closed " + str.tostring(tradeR, "#.##") + "R", alert.freq_once_per_bar_close)

inPos = posDir != 0

// ---------------------------------------------------------------------------
// 8) VISUALS + ALERTS + PERFORMANCE
// ---------------------------------------------------------------------------
plot(inPos ? curStop : na, "Live Stop",   color=color.new(color.red,0),  style=plot.style_linebr, linewidth=1)
plot(inPos ? curTP   : na, "Runner Target", color=color.new(color.teal,0), style=plot.style_linebr, linewidth=1)
plot(inPos and usePartial ? tp1Px : na, "Partial Target", color=color.new(color.teal,50), style=plot.style_linebr, linewidth=1)
plotshape(goLong,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=bull, size=size.small, text="LONG")
plotshape(goShort, title="Short", style=shape.triangledown, location=location.abovebar, color=bear, size=size.small, text="SHORT")
plotshape(partialHit, title="Partial", style=shape.circle, location=location.top, color=color.new(color.teal,20), size=size.tiny, text="TP1")
plotshape(exitHit, title="Exit",  style=shape.xcross,       location=location.top,      color=color.gray, size=size.tiny, text="exit")
bgcolor(lockout ? color.new(color.red, 92) : na, title="Locked out")

alertcondition(goLong,  "Long Entry",  "LONG {{ticker}} @ {{close}} | structure retrace + confluence + sweep")
alertcondition(goShort, "Short Entry", "SHORT {{ticker}} @ {{close}} | structure retrace + confluence + sweep")
alertcondition(partialHit, "Partial",  "PARTIAL {{ticker}} @ {{close}} | 1R hit, stop to BE")
alertcondition(exitHit, "Exit",        "EXIT {{ticker}} @ {{close}} | stop or target hit")

if showTable and barstate.islast
    var table tb = table.new(position.top_right, 2, 7, border_width=1)
    bgD = color.new(color.black, 30)
    table.cell(tb, 0, 0, "HTF bias", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 0, htfTrend==1?"Bull":htfTrend==-1?"Bear":"-", text_size=size.small, text_color=color.white, bgcolor=f_cellCol(htfTrend))
    table.cell(tb, 0, 1, "LTF trend", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 1, trend==1?"Bull":trend==-1?"Bear":"-", text_size=size.small, text_color=color.white, bgcolor=f_cellCol(trend))
    table.cell(tb, 0, 2, "Long conf", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 2, str.tostring(scoreLong)+"/4", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 3, "Short conf", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 3, str.tostring(scoreShort)+"/4", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 0, 4, "Position", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 4, posDir==1?(tookPartial?"LONG (BE)":"LONG"):posDir==-1?(tookPartial?"SHORT (BE)":"SHORT"):"flat", text_size=size.small, text_color=color.white, bgcolor=f_cellCol(posDir))
    table.cell(tb, 0, 5, "Day R", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 5, str.tostring(dayR, "#.##")+"R", text_size=size.small, text_color=dayR>=0?bull:bear, bgcolor=bgD)
    table.cell(tb, 0, 6, "Lockout", text_size=size.small, text_color=color.white, bgcolor=bgD)
    table.cell(tb, 1, 6, lockout?(dailyLossHit?"daily":"streak"):"no", text_size=size.small, text_color=color.white, bgcolor=lockout?bear:color.new(color.green,40))

if showPerf and barstate.islast
    wr = tradeCount > 0 ? winCount / tradeCount * 100 : na
    expR = tradeCount > 0 ? sumR / tradeCount : na
    var table pt = table.new(position.bottom_right, 2, 4, border_width=1)
    bgP = color.new(color.black, 30)
    table.cell(pt, 0, 0, "Virtual trades", text_size=size.small, text_color=color.white, bgcolor=bgP)
    table.cell(pt, 1, 0, str.tostring(tradeCount), text_size=size.small, text_color=color.white, bgcolor=bgP)
    table.cell(pt, 0, 1, "Win %", text_size=size.small, text_color=color.white, bgcolor=bgP)
    table.cell(pt, 1, 1, na(wr)?"-":str.tostring(wr, "#.#")+"%", text_size=size.small, text_color=color.white, bgcolor=bgP)
    table.cell(pt, 0, 2, "Expectancy", text_size=size.small, text_color=color.white, bgcolor=bgP)
    table.cell(pt, 1, 2, na(expR)?"-":str.tostring(expR, "#.##")+"R", text_size=size.small, text_color=na(expR)?color.white:(expR>=0?bull:bear), bgcolor=bgP)
    table.cell(pt, 0, 3, "Total R", text_size=size.small, text_color=color.white, bgcolor=bgP)
    table.cell(pt, 1, 3, str.tostring(sumR, "#.##")+"R", text_size=size.small, text_color=sumR>=0?bull:bear, bgcolor=bgP)
